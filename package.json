{
  "name": "{{ name }}",
  "version": "1.0.0",
  "private": true,
  "description": "{{ description }}",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "start": "next dev",
    "build": "next build",
    "preview": "next start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:junit": "vitest run --reporter=junit --outputFile=test-results/vitest-junit.xml",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:component-coverage": "node scripts/check-component-tests.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/postcss": "^4.3.2",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint-react/eslint-plugin": "^5.11.2",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "code-inspector-plugin": "^1.6.5",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-tailwindcss": "^4.0.6",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "oxfmt": "^0.58.0",
    "sass": "^1.101.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,html,md,yml,yaml}": "oxfmt --write --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx}": "eslint --fix --no-warn-ignored"
  },
  "engines": {
    "node": "^22.12.0 || ^24.11.0 || >=26.0.0"
  },
  "packageManager": "pnpm@11.10.0"
}
